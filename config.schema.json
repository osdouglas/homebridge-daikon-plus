{
  "pluginAlias": "DaikonPlus",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Daikon Plus"
      },
      "apiKey": {
        "title": "API Key",
        "type": "string",
        "required": true,
        "description": "Daikin One Open API key for this integration.",
        "x-schema-form": {
          "type": "password"
        }
      },
      "integratorEmail": {
        "title": "Integrator Email",
        "type": "string",
        "required": true,
        "description": "Email address used with the Daikin One app.",
        "x-schema-form": {
          "type": "username"
        }
      },
      "integratorToken": {
        "title": "Integrator Token",
        "type": "string",
        "required": true,
        "description": "Daikin One Open API integration token from the Daikin One app.",
        "x-schema-form": {
          "type": "password"
        }
      },
      "pollIntervalSeconds": {
        "title": "Poll Interval Seconds",
        "type": "integer",
        "default": 180,
        "minimum": 180
      },
      "requestTimeoutSeconds": {
        "title": "Request Timeout Seconds",
        "type": "integer",
        "default": 20,
        "minimum": 1
      },
      "includeDeviceName": {
        "title": "Include Device Name",
        "type": "boolean",
        "default": true
      },
      "deviceIds": {
        "title": "Device IDs",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "readonly": {
        "title": "Read Only",
        "type": "boolean",
        "default": false
      },
      "developerMode": {
        "title": "Developer Mode",
        "type": "boolean",
        "default": false,
        "description": "Enable verbose troubleshooting logs, including raw Daikin API payloads. Turn off after troubleshooting because payloads can include device identifiers and detailed HVAC state."
      }
    }
  },
  "form": [
    "name",
    "apiKey",
    "integratorEmail",
    "integratorToken",
    "pollIntervalSeconds",
    "requestTimeoutSeconds",
    "includeDeviceName",
    "deviceIds",
    "readonly",
    "developerMode"
  ]
}
