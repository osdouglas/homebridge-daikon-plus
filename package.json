{
  "displayName": "Homebridge Daikin One Open API",
  "name": "homebridge-daikin-one-openapi",
  "version": "0.1.0",
  "description": "Homebridge platform for Daikin One+ thermostats using Daikin One Open API integration tokens.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "README.md"
  ],
  "engines": {
    "node": "^20.18.0 || ^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "keywords": [
    "homebridge-plugin",
    "daikin",
    "daikin-one",
    "oneplus",
    "openapi",
