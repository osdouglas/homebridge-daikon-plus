{
  "displayName": "Homebridge Daikon Plus",
  "name": "homebridge-daikon-plus",
  "version": "0.1.0",
  "description": "Homebridge platform for Daikin One+ thermostats using Daikin One Open API integration tokens.",
  "author": "osdouglas",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/osdouglas/homebridge-daikon-plus#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdouglas/homebridge-daikon-plus.git"
  },
  "bugs": {
    "url": "https://github.com/osdouglas/homebridge-daikon-plus/issues"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "DEVELOPMENT.md",
    "DESIGN.md"
  ],
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0-beta.0"
  },
  "keywords": [
    "homebridge-plugin",
    "daikon-plus",
    "daikin",
    "daikin-one",
    "oneplus",
    "openapi",
    "hvac"
  ],
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "lint": "tsc --noEmit",
    "test": "rimraf ./dist && tsc && node --test test/*.test.mjs",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.18.0",
    "homebridge": "^1.8.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
